rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core check helpers
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuth() && 
        (getUserData().role == 'admin' || getUserData().role == 'root_admin' || request.auth.token.emailLower == 'joaopedromoladeoliveira@gmail.com');
    }
    
    function isRootAdmin() {
      return isAuth() && 
        (getUserData().role == 'root_admin' || request.auth.token.emailLower == 'joaopedromoladeoliveira@gmail.com');
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isRootAdmin();
    }

    // 2. Posts collection rules
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // 3. Comments collection rules
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // 4. Chats collection rules
    match /chats/{chatId} {
      allow read, write: if isAuth() && (request.auth.uid in resource.data.userIds || request.auth.uid in request.resource.data.userIds);
    }

    // 5. Messages collection rules
    match /messages/{messageId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId);
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId);
      allow update: if isAuth() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId);
      allow delete: if isAuth() && (request.auth.uid == resource.data.senderId);
    }

    // 6. Notifications collection rules
    match /notifications/{notifId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.recipientId);
      allow create: if isAuth();
      allow update: if isAuth() && (request.auth.uid == resource.data.recipientId);
      allow delete: if isAuth() && (request.auth.uid == resource.data.recipientId);
    }

    // 7. Follows collection rules
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.followerId || request.auth.uid == resource.data.followingId);
    }

    // 8. Reports collection rules
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
  }
}
