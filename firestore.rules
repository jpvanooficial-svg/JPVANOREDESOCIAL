rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core check helpers
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuth() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           (getUserData().role == 'admin' || getUserData().role == 'root_admin')) ||
          request.auth.token.email == 'joaopedromoladeoliveira@gmail.com' ||
          request.auth.token.email == 'jpvanoredesocial@gmail.com'
        );
    }
    
    function isRootAdmin() {
      return isAuth() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           getUserData().role == 'root_admin') ||
          request.auth.token.email == 'joaopedromoladeoliveira@gmail.com'
        );
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isRootAdmin();
    }

    // 2. Posts collection rules
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // 3. Comments collection rules
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // 4. Chats collection rules
    match /chats/{chatId} {
      allow read, write: if isAuth();
    }

    // 5. Messages collection rules
    match /messages/{messageId} {
      allow read, write: if isAuth();
    }

    // 6. Notifications collection rules
    match /notifications/{notifId} {
      allow read, write: if isAuth();
    }

    // 7. Follows collection rules
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.followerId || request.auth.uid == resource.data.followingId);
    }

    // 8. Reports collection rules
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // 9. Stories collection rules
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }
  }
}
